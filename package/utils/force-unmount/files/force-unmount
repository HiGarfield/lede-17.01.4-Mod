#!/bin/sh

# shellcheck shell=dash

. /usr/share/libubox/jshn.sh

MAX_TRY=5

_log() {
	logger -t "force-unmount" "$@"
	echo "$@"
}

##
# @brief 检查指定进程是否为祖先进程的后代
#
# 该函数用于检查给定的目标进程是否是指定祖先进程的后代（直接或间接子进程）。
# 它通过读取/proc文件系统中的进程状态信息来实现。
#
# @param target_pid 待检查的目标进程ID
# @param ancestor_pid 祖先进程ID
# @return 0 - 目标进程是祖先进程的后代
#         1 - 目标进程不是祖先进程的后代
#
# @usage
#   is_descendant_process 12345 100   # 检查PID=12345是否是PID=100的后代
#   if is_descendant_process "$child" "$parent"; then
#       echo "是后代进程"
#   else
#       echo "非后代或参数错误"
#   fi
#
# @note
#   1. 该函数依赖/proc文件系统，仅在Linux环境下有效。
#   2. 若目标进程已退出或/proc/[pid]/stat不可读，可能返回错误。
#   3. 参数必须为整数，否则直接返回1。
##
is_descendant_process() {
	local target_pid="$1"
	local ancestor_pid="$2"
	local current_pid="$target_pid"
	local depth=0

	# 参数校验
	{ [ -n "$target_pid" ] && [ -n "$ancestor_pid" ] &&
		[ "$target_pid" -eq "$target_pid" ] 2>/dev/null &&
		[ "$ancestor_pid" -eq "$ancestor_pid" ] 2>/dev/null; } || return 1

	[ "$target_pid" -eq "$ancestor_pid" ] && return 0

	while [ "$depth" -lt 128 ]; do
		depth=$((depth + 1))

		[ -r "/proc/$current_pid/stat" ] || return 1

		current_pid=$(awk '{sub(/^.*\)/, ""); print $2}' "/proc/$current_pid/stat")
		[ -z "$current_pid" ] || [ "$current_pid" -le 1 ] && return 1
		[ "$current_pid" -eq "$ancestor_pid" ] && return 0
	done

	return 1
}

##
# @brief 停止占用指定挂载点的所有服务
#
# 该函数通过检测占用指定挂载点的所有进程，并检查其所属服务实例，
# 停止所有与该挂载点关联的服务。
#
# @param mountpoint 需要检查的挂载点绝对路径（例如 "/mnt/usb"）
# @return 0  - 正常停止服务
#         1  - 读取服务列表失败
#
# @usage
#   stop_occupying_service "/mnt/sda1"  # 停止所有占用挂载点 /mnt/sda1 的服务
#
# @dependencies 依赖以下组件：
#   - lsof：用于获取占用挂载点的进程列表
#   - ubus：通过 `ubus call service list` 获取服务信息
#   - json：用于解析服务信息
#
# @note
# - 该函数需要 root 权限才能终止其他用户的进程。
# - 依赖 lsof 和 ubus 命令，确保已安装。
# - 函数会输出日志信息，记录停止的服务。
# - 函数会返回 0 表示正常停止，1 表示读取服务信息失败。
##
stop_occupying_service() {
	local mountpoint="$1"
	local pids services service instances instance pid running kill_flag

	# 获取占用挂载点的进程
	pids=$(lsof -t "$mountpoint" 2>/dev/null)
	[ -z "$pids" ] && return 0

	# 获取服务列表
	local raw_json
	raw_json="$(ubus call service list 2>/dev/null)"
	[ -z "$raw_json" ] && return 1

	json_init
	json_load "$raw_json" || return 1
	json_get_keys services

	for service in $services; do
		kill_flag=0

		json_select "$service" || continue
		if json_is_a instances object; then
			json_select instances || continue

			json_get_keys instances
			for instance in $instances; do
				[ "$kill_flag" -eq 1 ] && break

				json_select "$instance" || continue

				json_get_var pid pid
				json_get_var running running

				if [ "$running" = "1" ] &&
					[ -n "$pid" ] &&
					[ "$pid" -gt 1 ] &&
					[ -d "/proc/$pid" ]; then

					for p in $pids; do
						is_descendant_process "$p" "$pid" && {
							kill_flag=1
							break
						}
					done
				fi
				json_select ..
			done
			json_select ..
		fi
		json_select ..

		[ "$kill_flag" -eq 1 ] && {
			[ -e "/etc/init.d/$service" ] || continue
			_log "stopping service: ${service}"
			/etc/init.d/"$service" stop >/dev/null 2>&1
		}
	done

	return 0
}

##
# @brief 终止占用指定挂载点的所有进程
#
# @param mountpoint  要检查的挂载点路径（必需）
# @param force_kill  可选强制终止模式（数值类型）：
#                    - 0（默认）：发送 SIGTERM（15）正常终止信号
#                    - 非零值：发送 SIGKILL（9）强制立即终止
#
# @usage
#   kill_occupying_process /mnt/usb   # 优雅终止进程
#   kill_occupying_process /mnt/usb 1 # 强制终止进程
#
# @note
# - 需要 root 权限才能终止其他用户的进程
# - 依赖 lsof 命令，请确保已安装 lsof 包
# - force_kill 设定为1，会强制立即终止进程，可能导致数据丢失，慎用
##
kill_occupying_process() {
	local mountpoint="$1"
	local force_kill=$((${2:-0} != 0))
	local pid comm

	for pid in $(lsof -t "$mountpoint" 2>/dev/null); do
		[ -d "/proc/$pid" ] || continue

		comm=$(cat "/proc/$pid/comm" 2>/dev/null | tr -d '\n')
		[ -z "$comm" ] && comm="<unknown>"

		_log "killing process: $comm (pid=$pid)"

		if [ "$force_kill" -eq 1 ]; then
			kill -9 "$pid" 2>/dev/null || true
		else
			kill "$pid" 2>/dev/null || true
		fi
	done
}

##
# 主逻辑
##
[ "$#" -eq 1 ] || exit 1

mountpoint="$(echo "$1" | sed 's#//\+#/#g' | sed 's#\(.\)/$#\1#')"

[ -e "$mountpoint" ] || {
	_log "can't unmount ${mountpoint}: no such mount point"
	exit 1
}

if awk -v mp="$mountpoint" '$2==mp{f=1} END{exit !f}' /proc/mounts; then
	for try in $(seq $MAX_TRY); do
		_log "unmounting ${mountpoint}: try $try/$MAX_TRY"

		stop_occupying_service "$mountpoint"
		kill_occupying_process "$mountpoint" "$([ "$try" -eq $MAX_TRY ] && echo 1 || echo 0)"

		sync
		umount "$mountpoint" && {
			_log "${mountpoint} successfully unmounted"
			exit 0
		}
	done

	_log "can't unmount ${mountpoint}"
	exit 1
else
	_log "${mountpoint} is not mounted"
	exit 0
fi
